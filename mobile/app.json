{
  "expo": {
    "name": "SelfMap",
    "slug": "selfmap",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "selfmap",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.selfmap.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.selfmap.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@clerk/expo",
      [
        "expo-image-picker",
        {
          "photosPermission": "SelfMap 需要存取您的相片庫以上傳大頭貼。"
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "clerkPublishableKey": "$EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY",
      "apiBaseUrl": "$EXPO_PUBLIC_API_BASE_URL",
      "router": {},
      "eas": {
        "projectId": "66ff2bc9-f049-4478-885a-30f3421b1172"
      }
    }
  }
}
